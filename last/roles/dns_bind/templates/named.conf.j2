options {
    listen-on port 53 {
{% for ip in dns_listen_on_ipv4 %}
        {{ ip }};
{% endfor %}
    };
    listen-on-v6 { none; };
    directory "{{ dns_zone_dir }}";
    allow-query {
{% for item in dns_allow_query %}
        {{ item }};
{% endfor %}
    };
    recursion {{ 'yes' if dns_recursion else 'no' }};
{% if dns_forwarders | length > 0 %}
    forwarders {
{% for forwarder in dns_forwarders %}
        {{ forwarder }};
{% endfor %}
    };
{% endif %}
    dnssec-validation yes;
    auth-nxdomain no;
};

zone "{{ dns_zone_name }}" IN {
    type master;
    file "{{ dns_zone_file }}";
    allow-update { none; };
};

zone "{{ dns_reverse_zone_name }}" IN {
    type master;
    file "{{ dns_reverse_zone_file }}";
    allow-update { none; };
};

include "/etc/named.root.key";
